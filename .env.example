OPENAI_API_KEY=your-openai-api-key

# Optional agent model overrides
OG_AGENT_MODEL=openai/gpt-5.2-codex
# OG_AGENT_API_BASE=
# OG_AGENT_MODEL_TYPE=responses
# OG_AGENT_REASONING_EFFORT=high

# Optional daemon/TUI settings
OGD_SOCKET=/tmp/opengraphs-ogd.sock
OG_RUNTIME=local
# OG_GRAPH_LABELS={"train/loss":"Loss","train/accuracy":"Accuracy"}

# Optional training defaults
# OG_RUN_DIR=runs/demo
# OG_TRAINING_FILE=demo_train.py
# OG_TRAINING_CMD=python demo_train.py

# Demo script knobs
DEMO_LR=0.001
DEMO_BATCH=32
TB_LOG_DIR=runs/demo
ENABLE_TB=1
